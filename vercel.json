{
  "version": 2,
  "installCommand": "pip3 install -r requirements.txt && chmod +x build.sh && ./build.sh",
  "builds": [
    {
      "src": "mr_store_project/wsgi.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "15mb",
        "runtime": "python3.12"
      }
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "/static/$1",
      "headers": {
        "Cache-Control": "public, max-age=31536000, immutable"
      }
    },
    {
      "src": "/(.*)",
      "dest": "mr_store_project/wsgi.py"
    }
  ]
}
